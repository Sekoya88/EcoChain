# EcoChain AI — Environment Variables
# Copie ce fichier: cp .env.example .env
# Puis ajoute ta clé API Google

# Clé API Google (obligatoire pour les agents IA)
# Obtenir ici: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Configuration LLM (optionnel, valeurs par défaut)
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# Configuration API (optionnel)
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Configuration Frontend (optionnel)
BACKEND_URL=http://localhost:8000
